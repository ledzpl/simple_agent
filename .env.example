TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# codex is the default backend. It uses long polling, so no public inbound port is needed.
AGENT_BACKEND=codex
AGENT_TIMEOUT=5m
# AGENTS_FILE=agents.json
DEFAULT_AGENT=moderator

# Multi-agent debate mode for normal messages. Keep false unless you want every
# normal message to run multiple backend calls. Use /debate for one-off debates.
DEBATE_ENABLED=false
DEBATE_MAX_AGENTS=4
DEBATE_ROUNDS=1
DEBATE_SHOW_TRANSCRIPT=true

# Per-chat persistent conversation memory.
MEMORY_ENABLED=true
MEMORY_DIR=.telegram-memory
MEMORY_MAX_MESSAGES=20
MEMORY_MAX_CHARS=12000
MEMORY_REFINE=true
MEMORY_REFINE_MAX_CHARS=1000
MEMORY_REFINE_TIMEOUT=90s

# Codex backend
CODEX_BIN=codex
CODEX_WORKDIR=.
CODEX_SANDBOX=read-only
# CODEX_MODEL=gpt-5
# CODEX_EXTRA_ARGS=--search

# Ollama backend
# Run `ollama serve` and pull a model first, for example:
# ollama pull llama3.2
# AGENT_BACKEND=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_KEEP_ALIVE=5m

# For a local ChatGPT-compatible CLI, switch to:
# AGENT_BACKEND=command
# LOCAL_AGENT_COMMAND=chatgpt

# Development only. If true, any Telegram chat that can find the bot can run the local agent.
# TELEGRAM_ALLOW_ALL=false
