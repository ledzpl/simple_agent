TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# Optional access controls.
# TELEGRAM_ALLOWED_USER_IDS=123456789
# TELEGRAM_ALLOW_GROUPS=false

# Agent selection. Defaults to codex with agents.json when present.
# AGENT_BACKEND=codex
# AGENT_TIMEOUT=5m
# AGENT_SYSTEM_PROMPT=
# AGENTS_FILE=agents.json
# DEBATE_ENABLED=false

# Persistent per-chat memory.
# MEMORY_ENABLED=true
# MEMORY_DIR=.telegram-memory
# MEMORY_REFINE=true

# Codex backend.
# CODEX_BIN=codex
# CODEX_WORKDIR=.
# CODEX_SANDBOX=read-only
# CODEX_MODEL=gpt-5

# Ollama backend.
# AGENT_BACKEND=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Command backend.
# AGENT_BACKEND=command
# LOCAL_AGENT_COMMAND=chatgpt
# LOCAL_AGENT_COMMAND_ALLOWLIST=chatgpt,codex
